# Dashboard (Next.js 14+) environment — slice-20a
# Copy to .env.local for dev; baked at build time in prod (see Dockerfile ARG).

# FastAPI backend base URL. Exposed to the browser, so NOT a secret.
NEXT_PUBLIC_API_URL=http://localhost:8060

# Optional: API key attached to requests when running against a key-protected backend.
# Leave unset in dev when the backend's API_KEY env var is also unset.
# NEXT_PUBLIC_API_KEY=
