# ===========================================
# AI Agent System - Environment Configuration
# ===========================================
# Copy to .env.local for development, .env for production

# --- LLM Provider ---
# "ollama" for local development, "anthropic" for cloud
LLM_PROVIDER=ollama

# --- Ollama (Local) ---
OLLAMA_MODEL=llama3.1:8b
OLLAMA_BASE_URL=http://localhost:11434

# --- Anthropic (Cloud) ---
# ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Embeddings ---
# "local" uses FastEmbed (CPU, no API key needed)
# "api" uses OpenAI text-embedding-3-small
EMBEDDING_MODE=local

# --- OpenAI (for API embeddings only) ---
# OPENAI_API_KEY=sk-...

# --- Qdrant Vector Database ---
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=documents

# --- Application ---
ENVIRONMENT=development
LOG_LEVEL=INFO
APP_PORT=8060
CHAINLIT_PORT=3060
